# 极简会议系统 — 部署环境变量示例
# 复制为 .env 并填写（本部署实际只需 EXTERNAL_IP 与域名证书）

# 你的域名（已解析 A 记录指向 VPS 公网 IP）
DOMAIN=meet.example.com

# 申请 Let's Encrypt 证书用的邮箱
CERTBOT_EMAIL=admin@example.com

# ↓↓↓ VPS 公网 IP（同步改到 coturn/turnserver.conf 的 external-ip / relay-ip）↓↓↓
EXTERNAL_IP=1.2.3.4

# TURN 凭证（已自动注入到 dist 前端，无需手填；仅作记录）
TURN_USER=meeting
TURN_SECRET=TURN_SECRET_HERE
